PORT=8080
NODE_ENV=development

# Comma-separated frontend origins allowed by CORS.
# Defaults are also defined in server.js for local and Netlify deployments.
CLIENT_URLS=http://localhost:3000,http://127.0.0.1:3000,https://3mt-machine-tools.netlify.app,https://3mt-dashboard.netlify.app

MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
GOOGLE_CLIENT_ID=your_google_client_id

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_sender_gmail_address
SMTP_PASS=your_google_app_password
OTP_EMAIL_FROM="3MT Machine Tools <your_sender_gmail_address>"

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
